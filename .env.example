NEXT_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
# Clave publishable (recomendada) o anon JWT legacy:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública del sitio (emails de confirmación Supabase → /auth/callback). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Key de Resend para SMTP (obtener en https://resend.com/api-keys)
# Necesaria para envío de emails de confirmación en desarrollo local
RESEND_API_KEY=re_REPLACE_ME

# En Supabase Dashboard: Auth → Providers → habilitar "Anonymous sign-ins" para sesiones anónimas por defecto
